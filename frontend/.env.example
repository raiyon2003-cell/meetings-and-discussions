VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use full anon JWT from Supabase → Settings → API. Quotes are safe if the key contains "=":
VITE_SUPABASE_ANON_KEY="paste_anon_public_jwt_here"
# Your Express API origin (no /rest/v1). Local default matches vite proxy + backend PORT:
VITE_API_URL=http://127.0.0.1:4000
