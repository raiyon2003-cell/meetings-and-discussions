VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use full anon JWT from Supabase → Settings → API. Quotes are safe if the key contains "=":
VITE_SUPABASE_ANON_KEY="paste_anon_public_jwt_here"

# API base URL (no trailing slash, no /api suffix).
#
# Local dev (npm run dev):
#   Recommended: leave unset — the Vite dev server proxies /api → http://127.0.0.1:4000 (same origin, no CORS).
#   If you set http://127.0.0.1:4000 or http://localhost:4000, the app still uses that proxy in dev to avoid
#   localhost vs 127.0.0.1 browser CORS issues.
#
# Production (e.g. Vercel): set to your deployed API origin, e.g. https://your-api.onrender.com
#VITE_API_URL=
