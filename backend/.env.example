PORT=4000
NODE_ENV=development
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
JWT_SECRET=generate_a_long_random_string
# Comma-separated: local dev + every Vercel URL you use (production + preview)
FRONTEND_URL=http://localhost:5173,https://YOUR_APP.vercel.app
# Optional: allow any https://*.vercel.app origin (handy for preview deploys). Default off.
# CORS_ALLOW_VERCEL_PREVIEWS=true
