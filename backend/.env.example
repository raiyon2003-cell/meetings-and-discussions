PORT=4000
NODE_ENV=development
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
JWT_SECRET=generate_a_long_random_string
# Comma-separated: local dev + your production site (custom domain or vercel.app). No trailing slashes required.
FRONTEND_URL=http://localhost:5173,https://YOUR_APP.vercel.app
# Allow any https://*.vercel.app (preview deploys). Default: enabled. Set to false to allow only FRONTEND_URL origins.
# CORS_ALLOW_VERCEL_PREVIEWS=false
